# Backend API URL (only needed for production deployment)
# For development, API requests are proxied to localhost:3000
# VITE_API_BASE_URL=https://your-production-backend-url.com

# Telegram Bot Name (used for landing page redirect to https://t.me/<name>)
VITE_TELEGRAM_BOT_NAME=your_bot_name_here

# Invite link for the volleyball group (shown when registration is blocked; fallback if backend doesn't send it)
# e.g. https://t.me/+xxxxxxxxxxxx
VITE_TELEGRAM_GROUP_INVITE_LINK=
