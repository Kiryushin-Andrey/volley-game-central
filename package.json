{
  "name": "volley-game-central",
  "version": "1.0.0",
  "description": "Volley Game Central - A platform for organizing volleyball games",
  "scripts": {
    "tg-mini-app:dev": "cd tg-mini-app && PREVIEW_HOST=\"${PREVIEW_HOST}\" npm run dev",
    "tg-mini-app:build": "cd tg-mini-app && npm run build",
    "backend:dev": "docker compose up -d postgres && cd backend && npm run dev",
    "backend:build": "cd backend && npm run build",
    "dev": "concurrently \"npm run backend:dev\" \"npm run tg-mini-app:dev\"",
    "dev:local": "DEV_MODE=true npm run dev",
    "build": "npm run backend:build && npm run tg-mini-app:build",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "bunq-mock:dev": "cd bunq-mock && npm run dev",
    "e2e:server": "bash scripts/playwright-dev-server.sh",
    "e2e:server:restrictions": "POSITIONS_GAME_LEVEL_RESTRICTIONS_ENABLED=true bash scripts/playwright-dev-server.sh",
    "test:e2e": "playwright test",
    "test:e2e:restrictions": "POSITIONS_GAME_LEVEL_RESTRICTIONS_ENABLED=true playwright test e2e/player-levels-restrictions.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth-session.spec.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "pg": "^8.20.0"
  },
  "dependencies": {
    "typescript": "^5.9.2"
  }
}
