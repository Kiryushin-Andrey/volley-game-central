####################################
# Volley Game Central - Backend ENV #
####################################

# Server
PORT=3000

# CORS / WebApp URL (public HTTPS URL used by Telegram WebApp button)
# For local dev, set this to your tunnel URL when testing in Telegram
# e.g. https://abc123.pinggy.link
MINI_APP_URL=http://127.0.0.1:3001

# Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=volley_game_central

# Telegram Bot
# Obtain from @BotFather
TELEGRAM_BOT_TOKEN=

# Optional: announcements to a group/topic
TELEGRAM_GROUP_ID=
TELEGRAM_TOPIC_ID=

# Bunq API
# Override only if you use a custom endpoint (rare)
BUNQ_API_URL=https://api.bunq.com/v1
# E2E / local: bunq-mock listens at http://127.0.0.1:3998/v1 (npm run bunq-mock:dev from repo root).

# Optional: used to build email-like aliases in payment requests
EMAIL_DOMAIN=volley-game-central.com

# SMS (Twilio) - optional in dev; required in prod for phone auth
# Create at https://www.twilio.com/
#
# You can authenticate with:
#    - TWILIO_ACCOUNT_SID (starts with AC)
#    - TWILIO_API_KEY_SID (starts with SK)
#    - TWILIO_API_KEY_SECRET
#
# Messaging Service SID is required to send messages
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_MESSAGING_SERVICE_SID=

# App name used in SMS texts
APP_NAME=VolleyBot

# JWT secret for signing auth cookies
JWT_SECRET=

# 5-1 player-level restrictions (FR-2). When unset, the hardcoded default in
# backend source applies. Set to true/1/yes to force enforcement on (e.g. local/staging tests).
# FIVE_ONE_LEVEL_RESTRICTIONS_ENABLED=

